<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="HTCommander.Desktop.Dialogs.SettingsDialog"
        Title="Settings"
        Width="720" Height="620"
        WindowStartupLocation="CenterOwner"
        CanResize="False"
        Background="{DynamicResource SurfaceBase}"
        FontFamily="Inter">
    <DockPanel Margin="0">
        <!-- Bottom buttons -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceContainerLow}" Padding="14,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                <Button Name="OkButton" Content="OK" Click="OkButton_Click" Padding="24,6"
                        Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}"
                        FontWeight="SemiBold" CornerRadius="4" />
                <Button Content="Cancel" Click="CancelButton_Click" Padding="24,6" CornerRadius="4" />
            </StackPanel>
        </Border>

        <Grid ColumnDefinitions="180,*">
            <!-- Left sidebar -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceContainer}" Padding="8,14">
                <DockPanel>
                    <TextBlock DockPanel.Dock="Top" Text="SYSTEM PARAMETERS" FontSize="10" FontWeight="Bold"
                               LetterSpacing="1.5" Foreground="{DynamicResource OnSurfaceVariant}"
                               Margin="10,0,0,14" />
                    <ListBox Name="CategoryList" SelectionChanged="CategoryList_SelectionChanged"
                             Background="Transparent" BorderThickness="0">
                        <ListBoxItem Content="General" IsSelected="True" />
                        <ListBoxItem Content="APRS" />
                        <ListBoxItem Content="Voice" />
                        <ListBoxItem Content="Winlink" />
                        <ListBoxItem Content="Servers" />
                        <ListBoxItem Content="Data Sources" />
                        <ListBoxItem Content="Audio" />
                        <ListBoxItem Content="Modem" />
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Right content area -->
            <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto" Padding="18,14">
                <Grid>

                <!-- General Panel -->
                <StackPanel Name="GeneralPanel" Spacing="14">
                    <TextBlock Text="GENERAL" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="An Amateur radio license is required to transmit."
                                       Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" TextWrapping="Wrap" />
                            <Grid ColumnDefinitions="110,*">
                                <TextBlock Grid.Column="0" Text="Theme:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="ThemeCombo" Grid.Column="1" Width="160" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="Auto (System)" Tag="Auto" />
                                    <ComboBoxItem Content="Light" Tag="Light" />
                                    <ComboBoxItem Content="Dark" Tag="Dark" />
                                </ComboBox>
                            </Grid>
                            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Call Sign:" VerticalAlignment="Center" FontSize="11" />
                                <TextBox Name="CallSignBox" Grid.Row="0" Grid.Column="1" Width="140"
                                         MaxLength="6" HorizontalAlignment="Left"
                                         TextChanged="CallSignBox_TextChanged" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Station ID:" VerticalAlignment="Center" Margin="0,8,0,0" FontSize="11" />
                                <ComboBox Name="StationIdCombo" Grid.Row="1" Grid.Column="1" Width="80"
                                          HorizontalAlignment="Left" Margin="0,8,0,0" />
                            </Grid>
                            <CheckBox Name="AllowTransmitCheck" Content="Allow Transmit" IsEnabled="False" />
                            <TextBlock Name="TransmitWarning" Text="Enter a valid call sign (3+ characters) to enable transmit."
                                       Foreground="#F44336" FontSize="11" Margin="24,0,0,0" />
                            <CheckBox Name="CheckUpdatesCheck" Content="Check for updates on startup" />
                        </StackPanel>
                    </Border>
                    <Button Name="ResetDefaultsButton" Content="Reset All Settings to Defaults"
                            Click="ResetDefaults_Click" Padding="12,6"
                            HorizontalAlignment="Left" CornerRadius="4" />
                </StackPanel>

                <!-- APRS Panel -->
                <StackPanel Name="AprsPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="APRS ROUTES" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" Spacing="4" Margin="0,10,0,0">
                                <Button Content="Add" Click="AddRoute_Click" Padding="12,4" CornerRadius="4"
                                        Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}" FontWeight="SemiBold" />
                                <Button Name="EditRouteBtn" Content="Edit" Click="EditRoute_Click" Padding="12,4" IsEnabled="False" CornerRadius="4" />
                                <Button Name="DeleteRouteBtn" Content="Delete" Click="DeleteRoute_Click" Padding="12,4" IsEnabled="False" CornerRadius="4" />
                            </StackPanel>
                            <DataGrid Name="AprsRoutesGrid" AutoGenerateColumns="False"
                                      IsReadOnly="True" SelectionChanged="AprsRoutesGrid_SelectionChanged"
                                      Background="Transparent" BorderThickness="0" MinHeight="120">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="Name" Width="150" Binding="{Binding Name}" />
                                    <DataGridTextColumn Header="Route" Width="*" Binding="{Binding Route}" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </DockPanel>
                    </Border>
                </StackPanel>

                <!-- Voice Panel -->
                <StackPanel Name="VoicePanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="VOICE SETTINGS" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Language:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="VoiceLanguageCombo" Grid.Row="0" Grid.Column="1" Width="220" HorizontalAlignment="Left" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TTS Voice:" VerticalAlignment="Center" Margin="0,8,0,0" FontSize="11" />
                                <ComboBox Name="VoiceCombo" Grid.Row="1" Grid.Column="1" Width="280" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            </Grid>
                            <CheckBox Name="SpeechToTextCheck" Content="Enable Speech-to-Text (Whisper)" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Winlink Panel -->
                <StackPanel Name="WinlinkPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="WINLINK" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="110,*">
                                <TextBlock Grid.Column="0" Text="Password:" VerticalAlignment="Center" FontSize="11" />
                                <TextBox Name="WinlinkPasswordBox" Grid.Column="1" Width="220"
                                         PasswordChar="&#x25CF;" MaxLength="128" HorizontalAlignment="Left" />
                            </Grid>
                            <CheckBox Name="WinlinkUseStationIdCheck" Content="Use Station ID in Winlink address" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Servers Panel -->
                <StackPanel Name="ServersPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="SERVER CONFIGURATION" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />

                    <!-- Network -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="NETWORK" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="ServerBindAllCheck" Content="Allow remote access (bind to all network interfaces)" />
                            <StackPanel Spacing="4">
                                <CheckBox Name="TlsEnabledCheck" Content="Enable TLS/HTTPS (required for mobile microphone over LAN)" />
                                <TextBlock Text="Generates a self-signed certificate. Accept the browser security warning on first connect."
                                           Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Web Server -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="WEB SERVER" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="WebServerCheck" Content="Enable Web Server" />
                            <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontSize="11" />
                                <NumericUpDown Name="WebPortUpDown" Grid.Column="1" Width="120"
                                               Minimum="1" Maximum="65535" Value="8080" HorizontalAlignment="Left" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- AGWPE -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="AGWPE SERVER" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="AgwpeServerCheck" Content="Enable AGWPE Server" />
                            <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontSize="11" />
                                <NumericUpDown Name="AgwpePortUpDown" Grid.Column="1" Width="120"
                                               Minimum="1" Maximum="65535" Value="8000" HorizontalAlignment="Left" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Rigctld -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="RIGCTLD SERVER" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="RigctldServerCheck" Content="Enable Rigctld Server (Hamlib)" />
                            <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontSize="11" />
                                <NumericUpDown Name="RigctldPortUpDown" Grid.Column="1" Width="120"
                                               Minimum="1" Maximum="65535" Value="4532" HorizontalAlignment="Left" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- CAT Server -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="CAT SERVER" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="CatServerCheck" Content="Enable CAT Server (Kenwood TS-2000)" />
                            <Grid Name="CatComPortPanel" ColumnDefinitions="Auto,Auto" Margin="24,0,0,0" IsVisible="False">
                                <TextBlock Grid.Column="0" Text="COM Port:" VerticalAlignment="Center" Margin="0,0,8,0" FontSize="11" />
                                <ComboBox Name="CatComPortCombo" Grid.Column="1" Width="120" />
                            </Grid>
                            <TextBlock Name="CatPortLabel" Text="" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" Margin="24,0,0,0" />
                        </StackPanel>
                    </Border>

                    <!-- Virtual Audio -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="VIRTUAL AUDIO" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="VirtualAudioCheck" Content="Enable Virtual Audio Bridge" />
                            <TextBlock Text="Creates virtual audio devices for external software (requires PulseAudio/PipeWire)."
                                       Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <!-- MCP Server -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="MCP SERVER" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <CheckBox Name="McpServerCheck" Content="Enable MCP Server (AI Control)" />
                            <Grid ColumnDefinitions="110,*" Margin="24,0,0,0">
                                <TextBlock Grid.Column="0" Text="Port:" VerticalAlignment="Center" FontSize="11" />
                                <NumericUpDown Name="McpPortUpDown" Grid.Column="1" Width="120"
                                               Minimum="1" Maximum="65535" Value="5678" HorizontalAlignment="Left" />
                            </Grid>
                            <CheckBox Name="McpDebugCheck" Content="Enable debug tools (DataBroker inspection, event dispatch)"
                                      Margin="24,0,0,0" />
                            <TextBlock Text="Exposes radio control and state via Model Context Protocol for AI assistants (Claude Code, etc.)."
                                       Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" Margin="24,0,0,0" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>

                    <TextBlock Name="PortWarning" Text="" Foreground="#F44336" FontSize="11" />
                </StackPanel>

                <!-- Data Sources Panel -->
                <StackPanel Name="DataSourcesPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="DATA SOURCES" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />

                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="AIRPLANE TRACKING" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <Grid ColumnDefinitions="100,*,Auto">
                                <TextBlock Grid.Column="0" Text="Server URL:" VerticalAlignment="Center" FontSize="11" />
                                <TextBox Name="AirplaneServerBox" Grid.Column="1"
                                         Watermark="http://localhost:8080/data/aircraft.json" />
                                <Button Grid.Column="2" Content="Test" Click="TestAirplaneServer_Click"
                                        Padding="12,4" Margin="8,0,0,0" CornerRadius="4" />
                            </Grid>
                            <TextBlock Name="AirplaneTestResult" Text="" FontSize="10" Margin="100,0,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="GPS SERIAL PORT" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Serial Port:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="GpsPortCombo" Grid.Row="0" Grid.Column="1" Width="180" HorizontalAlignment="Left" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Baud Rate:" VerticalAlignment="Center" Margin="0,8,0,0" FontSize="11" />
                                <ComboBox Name="GpsBaudCombo" Grid.Row="1" Grid.Column="1" Width="120" HorizontalAlignment="Left" Margin="0,8,0,0">
                                    <ComboBoxItem Content="4800" Tag="4800" />
                                    <ComboBoxItem Content="9600" Tag="9600" />
                                    <ComboBoxItem Content="19200" Tag="19200" />
                                    <ComboBoxItem Content="38400" Tag="38400" />
                                    <ComboBoxItem Content="57600" Tag="57600" />
                                    <ComboBoxItem Content="115200" Tag="115200" />
                                </ComboBox>
                            </Grid>
                            <TextBlock Name="GpsStatusLabel" Text="" FontSize="10" Margin="100,4,0,0" />
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="REPEATERBOOK DEFAULTS" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <Grid ColumnDefinitions="100,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Country:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="RBCountryCombo" Grid.Row="0" Grid.Column="1" Width="200" HorizontalAlignment="Left"
                                          SelectionChanged="RBCountryCombo_SelectionChanged" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="State:" VerticalAlignment="Center" Margin="0,8,0,0" FontSize="11" />
                                <ComboBox Name="RBStateCombo" Grid.Row="1" Grid.Column="1" Width="200" HorizontalAlignment="Left" Margin="0,8,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Audio Panel -->
                <StackPanel Name="AudioPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="AUDIO" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />

                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="DEVICES" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />
                            <Grid ColumnDefinitions="110,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Output Device:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="OutputDeviceCombo" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Stretch" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Input Device:" VerticalAlignment="Center" Margin="0,8,0,0" FontSize="11" />
                                <ComboBox Name="InputDeviceCombo" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Stretch" Margin="0,8,0,0" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <TextBlock Text="LEVELS" FontSize="9" FontWeight="Bold" LetterSpacing="1.5"
                                       Foreground="{DynamicResource OnSurfaceVariant}" />

                            <!-- Radio Volume -->
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Radio Volume" FontSize="11" />
                                    <TextBlock Name="VolumeValueText" Grid.Column="1" Text="0" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                                </Grid>
                                <Slider Name="VolumeSlider" Minimum="0" Maximum="15"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="VolumeSlider_Changed" />
                            </StackPanel>

                            <!-- Squelch -->
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Squelch Level" FontSize="11" />
                                    <TextBlock Name="SquelchValueText" Grid.Column="1" Text="0" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                                </Grid>
                                <Slider Name="SquelchSlider" Minimum="0" Maximum="9"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="SquelchSlider_Changed" />
                            </StackPanel>

                            <!-- Output Volume -->
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Output Volume" FontSize="11" />
                                    <TextBlock Name="OutputVolumeText" Grid.Column="1" Text="100%" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                                </Grid>
                                <Slider Name="OutputVolumeSlider" Minimum="0" Maximum="100"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        ValueChanged="OutputVolumeSlider_Changed" />
                                <CheckBox Name="MuteCheck" Content="Mute" Click="Mute_Click" />
                            </StackPanel>

                            <!-- Mic Gain -->
                            <StackPanel Spacing="4">
                                <Grid ColumnDefinitions="*,Auto">
                                    <TextBlock Text="Mic Gain" FontSize="11" />
                                    <TextBlock Name="MicGainText" Grid.Column="1" Text="100%" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                                </Grid>
                                <Slider Name="MicGainSlider" Minimum="0" Maximum="200"
                                        TickFrequency="1" IsSnapToTickEnabled="True"
                                        Value="100"
                                        ValueChanged="MicGainSlider_Changed" />
                                <TextBlock Text="0% = mute, 100% = normal, 200% = 2x boost" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" />
                            </StackPanel>

                            <TextBlock Name="AudioControlsNote" Text="Connect a radio to adjust volume and squelch."
                                       Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" FontStyle="Italic" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Modem Panel -->
                <StackPanel Name="ModemPanel" Spacing="14" IsVisible="False">
                    <TextBlock Text="MODEM" FontSize="10" FontWeight="Bold" LetterSpacing="1.5"
                               Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,0,0,4" />
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="12">
                            <Grid ColumnDefinitions="110,*">
                                <TextBlock Grid.Column="0" Text="Modem Mode:" VerticalAlignment="Center" FontSize="11" />
                                <ComboBox Name="ModemModeCombo" Grid.Column="1" Width="180" HorizontalAlignment="Left">
                                    <ComboBoxItem Content="None" Tag="None" />
                                    <ComboBoxItem Content="AFSK 1200" Tag="AFSK1200" />
                                    <ComboBoxItem Content="PSK 2400" Tag="PSK2400" />
                                    <ComboBoxItem Content="PSK 4800" Tag="PSK4800" />
                                    <ComboBoxItem Content="G3RUH 9600" Tag="G3RUH9600" />
                                </ComboBox>
                            </Grid>
                            <TextBlock Text="The software modem decodes digital signals from the radio audio stream. Enable audio streaming (Radio menu) for the modem to function."
                                       Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </StackPanel>

                </Grid>
            </ScrollViewer>
        </Grid>
    </DockPanel>
</Window>
