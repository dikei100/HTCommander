<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:tabs="clr-namespace:HTCommander.Desktop.TabControls"
        x:Class="HTCommander.Desktop.MainWindow"
        Title="HTCommander-X"
        Width="1200" Height="800"
        MinWidth="600" MinHeight="400"
        FontFamily="Inter"
        Background="{DynamicResource SurfaceBase}">
    <Window.Styles>
        <Style Selector="Border.vfoCard:pointerover">
            <Setter Property="Opacity" Value="0.85" />
        </Style>
        <!-- Sidebar nav item styles -->
        <Style Selector="ListBoxItem.sidebarItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2,1" />
            <Setter Property="MinHeight" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource SidebarInactiveText}" />
            <Setter Property="CornerRadius" Value="6" />
        </Style>
        <Style Selector="ListBoxItem.sidebarItem:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SidebarHover}" />
        </Style>
        <Style Selector="ListBoxItem.sidebarItem:selected /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource SurfaceContainerHigh}" />
        </Style>
    </Window.Styles>

    <DockPanel>
        <!-- Hidden Menu (preserved for code-behind named control references) -->
        <Menu DockPanel.Dock="Top" IsVisible="False" Height="0">
            <MenuItem Header="_File">
                <MenuItem Name="MenuConnect" Header="_Connect..." Click="ConnectButton_Click" />
                <MenuItem Name="MenuDisconnect" Header="_Disconnect" Click="DisconnectButton_Click" IsEnabled="False" />
                <Separator />
                <MenuItem Name="MenuSettings" Header="_Settings..." Click="MenuSettings_Click" />
                <Separator />
                <MenuItem Header="E_xit" Click="MenuExit_Click" />
            </MenuItem>
            <MenuItem Header="_Radio">
                <MenuItem Name="MenuDualWatch" Header="_Dual Watch" Click="MenuDualWatch_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="DualWatchCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuScan" Header="_Scan" Click="MenuScan_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="ScanCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuGpsEnabled" Header="_GPS Enabled" Click="MenuGpsEnabled_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="GpsEnabledCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Name="MenuAudioEnabled" Header="_Audio Enabled" Click="MenuAudioEnabled_Click" IsEnabled="False">
                    <MenuItem.Icon>
                        <CheckBox Name="AudioEnabledCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuSoftwareModem" Header="Software _Modem" Click="MenuSoftwareModem_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="SoftwareModemCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <Separator />
                <MenuItem Name="MenuExportChannels" Header="_Export Channels..." Click="MenuExportChannels_Click" IsEnabled="False" />
                <MenuItem Name="MenuImportChannels" Header="_Import Channels..." Click="MenuImportChannels_Click" />
                <MenuItem Name="MenuRepeaterBook" Header="Import from _RepeaterBook..." Click="MenuRepeaterBook_Click" />
            </MenuItem>
            <MenuItem Header="_View">
                <MenuItem Name="MenuRadioPanel" Header="_Radio Panel" Click="MenuRadioPanel_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="RadioPanelCheck" IsChecked="True" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuAllChannels" Header="_All Channels" Click="MenuAllChannels_Click">
                    <MenuItem.Icon>
                        <CheckBox Name="AllChannelsCheck" BorderThickness="0" IsHitTestVisible="False" />
                    </MenuItem.Icon>
                </MenuItem>
                <MenuItem Name="MenuRadioSelect" Header="Active _Radio" IsVisible="False" />
                <Separator />
                <MenuItem Name="MenuSpectrogram" Header="S_pectrogram..." Click="MenuSpectrogram_Click" />
                <MenuItem Name="MenuAudioClips" Header="Audio _Clips..." Click="MenuAudioClips_Click" IsEnabled="False" />
            </MenuItem>
            <MenuItem Header="_Help">
                <MenuItem Name="MenuRadioInfo" Header="Radio _Information..." Click="MenuRadioInfo_Click" IsEnabled="False" />
                <MenuItem Name="MenuGpsInfo" Header="_GPS Information..." Click="MenuGpsInfo_Click" IsEnabled="False" />
                <Separator />
                <MenuItem Name="MenuCheckUpdates" Header="Check for _Updates..." Click="MenuCheckUpdates_Click" />
                <Separator />
                <MenuItem Header="_About HTCommander-X..." Click="MenuAbout_Click" />
            </MenuItem>
        </Menu>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceBase}" Padding="16,8" Height="48">
            <Grid ColumnDefinitions="Auto,*,Auto">
                <!-- Brand -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="HTCommander-X" FontSize="14" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryAccent}" VerticalAlignment="Center" />
                    <TextBlock Name="HeaderSectionName" Text="COMMUNICATION HUB" FontSize="16"
                               Foreground="{DynamicResource OnSurface}" VerticalAlignment="Center"
                               FontWeight="Bold" LetterSpacing="1" />
                </StackPanel>
                <!-- Center status -->
                <TextBlock Name="StatusText" Grid.Column="1" VerticalAlignment="Center"
                           HorizontalAlignment="Center" Text="Not connected"
                           Foreground="{DynamicResource OnSurfaceVariant}" FontSize="12" />
                <!-- Right controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button Name="ConnectButton" Content="CONNECT" Click="ConnectButton_Click"
                            Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}"
                            FontWeight="Bold" FontSize="12" Padding="16,6" CornerRadius="4" />
                    <Button Name="DisconnectButton" Content="DISCONNECT" Click="DisconnectButton_Click"
                            IsEnabled="False" IsVisible="False"
                            Background="{DynamicResource ErrorAccent}" Foreground="{DynamicResource OnPrimary}"
                            FontWeight="Bold" FontSize="12" Padding="16,6" CornerRadius="4" />
                    <Button Content="&#x2699;" Click="MenuSettings_Click" FontSize="18"
                            Background="Transparent" Foreground="{DynamicResource OnSurfaceVariant}"
                            Padding="8,4" VerticalAlignment="Center" />
                    <Button Content="&#x2630;" FontSize="16" Padding="8,4"
                            Background="Transparent" Foreground="{DynamicResource OnSurfaceVariant}"
                            VerticalAlignment="Center">
                        <Button.Flyout>
                            <MenuFlyout>
                                <MenuItem Header="Connect..." Click="ConnectButton_Click" />
                                <MenuItem Header="Disconnect" Click="DisconnectButton_Click" />
                                <MenuItem Header="-" />
                                <MenuItem Header="Dual Watch" Click="MenuDualWatch_Click" />
                                <MenuItem Header="Scan" Click="MenuScan_Click" />
                                <MenuItem Header="GPS Enabled" Click="MenuGpsEnabled_Click" />
                                <MenuItem Header="-" />
                                <MenuItem Header="Audio Enabled" Click="MenuAudioEnabled_Click" />
                                <MenuItem Header="Software Modem" Click="MenuSoftwareModem_Click" />
                                <MenuItem Header="-" />
                                <MenuItem Header="Export Channels..." Click="MenuExportChannels_Click" />
                                <MenuItem Header="Import Channels..." Click="MenuImportChannels_Click" />
                                <MenuItem Header="Import from RepeaterBook..." Click="MenuRepeaterBook_Click" />
                                <MenuItem Header="-" />
                                <MenuItem Header="Radio Panel" Click="MenuRadioPanel_Click" />
                                <MenuItem Header="All Channels" Click="MenuAllChannels_Click" />
                                <MenuItem Header="Spectrogram..." Click="MenuSpectrogram_Click" />
                                <MenuItem Header="Audio Clips..." Click="MenuAudioClips_Click" />
                                <MenuItem Header="-" />
                                <MenuItem Header="Radio Information..." Click="MenuRadioInfo_Click" />
                                <MenuItem Header="GPS Information..." Click="MenuGpsInfo_Click" />
                                <MenuItem Header="Check for Updates..." Click="MenuCheckUpdates_Click" />
                                <MenuItem Header="About HTCommander-X..." Click="MenuAbout_Click" />
                            </MenuFlyout>
                        </Button.Flyout>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Status bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceContainerLow}" Padding="16,5" Height="28">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                <TextBlock Name="StatusBarText" Text="Ready" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10"
                           VerticalAlignment="Center" />
                <TextBlock Name="StatusBarGps" Grid.Column="1" Text="" Foreground="{DynamicResource Outline}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,20,0" FontFamily="Consolas,Liberation Mono,monospace" />
                <TextBlock Name="BatteryStatusText" Grid.Column="2" Text="" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10"
                           VerticalAlignment="Center" Margin="0,0,20,0" />
                <TextBlock Text="ENCRYPTION: AES-256" Foreground="{DynamicResource Outline}" FontSize="9"
                           Grid.Column="3" VerticalAlignment="Center" LetterSpacing="0.5" />
            </Grid>
        </Border>

        <!-- Main content: Sidebar + Radio Panel + Tab Content -->
        <Grid ColumnDefinitions="220,Auto,*">
            <!-- Sidebar navigation -->
            <Border Grid.Column="0" Background="{DynamicResource SidebarBackground}">
                <DockPanel>
                    <!-- Sidebar header: callsign -->
                    <StackPanel DockPanel.Dock="Top" Margin="16,16,16,8">
                        <TextBlock Name="SidebarCallsign" Text="OPERATOR" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryAccent}"
                                   LetterSpacing="1.5" />
                        <TextBlock Name="SidebarStatus" Text="SIGNAL STABLE" FontSize="10"
                                   Foreground="{DynamicResource OnSurfaceVariant}" Margin="0,2,0,0"
                                   LetterSpacing="1" />
                    </StackPanel>

                    <!-- Bottom section -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="8,0,8,12" Spacing="2">
                        <Button Content="Settings" Click="MenuSettings_Click"
                                Background="Transparent" Foreground="{DynamicResource SidebarInactiveText}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,8" FontSize="12" />
                        <Button Content="About" Click="MenuAbout_Click"
                                Background="Transparent" Foreground="{DynamicResource SidebarInactiveText}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,8" FontSize="12" />
                    </StackPanel>

                    <!-- Nav items -->
                    <ListBox Name="SidebarNav" Background="Transparent" BorderThickness="0"
                             Margin="8,8,8,8" Padding="0"
                             SelectionChanged="SidebarNav_SelectionChanged" SelectedIndex="0">
                        <ListBoxItem Classes="sidebarItem" Tag="Communication">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4E1;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Communication" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Contacts">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F465;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Contacts" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Logbook">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4D3;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Logbook" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Packets">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4E6;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Packets" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Terminal">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4BB;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Terminal" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="BBS">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4CB;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="BBS" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Mail">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x2709;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Mail" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Torrent">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4BE;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Torrent" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="APRS">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F4E1;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="APRS" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Map">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F5FA;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Map" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                        <ListBoxItem Classes="sidebarItem" Tag="Debug">
                            <Border Padding="10,9" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="&#x1F527;" FontSize="14" VerticalAlignment="Center" />
                                    <TextBlock Text="Debug" FontSize="12" VerticalAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </ListBoxItem>
                    </ListBox>
                </DockPanel>
            </Border>

            <!-- Radio info panel (shown on Communication tab) -->
            <Border Name="RadioPanel" Grid.Column="1" Width="280" IsVisible="False"
                    Background="{DynamicResource SurfaceContainerLow}">
                <ScrollViewer>
                    <StackPanel Margin="16,16,16,16" Spacing="12">

                        <!-- Radio status card (compact, no image) -->
                        <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                            <StackPanel Spacing="4">
                                <TextBlock Name="RadioNameText" Text="VR-N76" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource OnSurface}" />
                                <TextBlock Name="RadioStateText" Text="Disconnected" FontSize="11"
                                           Foreground="{DynamicResource TertiaryAccent}" />
                                <Grid ColumnDefinitions="*,*" Margin="0,6,0,0">
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Name="ScreenRssiText" Text="--.- dB" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryAccent}" />
                                        <TextBlock Text="SIGNAL" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1">
                                        <TextBlock Name="BatteryText" Text="--%" FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource OnSurface}" />
                                        <TextBlock Text="BATTERY" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Hidden controls for screen overlay (preserved for code-behind) -->
                        <TextBlock Name="ScreenVfoA" Text="----.---" IsVisible="False" />
                        <TextBlock Name="ScreenVfoB" Text="----.---" IsVisible="False" />

                        <!-- Frequency display: VFO A (large) -->
                        <StackPanel Spacing="2">
                            <TextBlock Text="FREQUENCY MATCH" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1.5" />
                        </StackPanel>

                        <!-- VFO A detail -->
                        <Border Name="VfoACard" Classes="vfoCard" Background="{DynamicResource SurfaceContainer}"
                                CornerRadius="8" Padding="14,12" Cursor="Hand" DoubleTapped="VfoACard_DoubleTapped">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change Channel..." Click="VfoAChangeChannel_Click" />
                                    <MenuItem Header="Edit Frequency..." Click="VfoAEditFreq_Click" />
                                    <MenuItem Header="Quick Frequency..." Click="VfoAQuickFreq_Click" />
                                    <Separator />
                                    <MenuItem Name="VfoAFreqModeItem" Header="Frequency Mode" Click="VfoAFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="VfoAFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel>
                                <TextBlock Name="VfoAName" Text="--" FontSize="10" Foreground="{DynamicResource PrimaryAccent}"
                                           FontWeight="SemiBold" LetterSpacing="1" />
                                <TextBlock Name="VfoAFreq" Text="--- .--- MHz" FontSize="28" Foreground="{DynamicResource PrimaryAccent}"
                                           FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- VFO B detail -->
                        <Border Name="VfoBCard" Classes="vfoCard" Background="{DynamicResource SurfaceContainer}"
                                CornerRadius="8" Padding="14,10" Cursor="Hand" DoubleTapped="VfoBCard_DoubleTapped">
                            <Border.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Change Channel..." Click="VfoBChangeChannel_Click" />
                                    <MenuItem Header="Edit Frequency..." Click="VfoBEditFreq_Click" />
                                    <MenuItem Header="Quick Frequency..." Click="VfoBQuickFreq_Click" />
                                    <Separator />
                                    <MenuItem Name="VfoBFreqModeItem" Header="Frequency Mode" Click="VfoBFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="VfoBFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </Border.ContextMenu>
                            <StackPanel>
                                <TextBlock Name="VfoBName" Text="--" FontSize="10" Foreground="{DynamicResource TertiaryAccent}"
                                           FontWeight="SemiBold" LetterSpacing="1" />
                                <TextBlock Name="VfoBFreq" Text="--- .--- MHz" FontSize="20" Foreground="{DynamicResource OnSurface}"
                                           FontFamily="Consolas,Liberation Mono,monospace" FontWeight="Bold" Margin="0,2,0,0" />
                            </StackPanel>
                        </Border>

                        <!-- RSSI bar -->
                        <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="6" Padding="14,8">
                            <Grid ColumnDefinitions="40,*" RowDefinitions="Auto,Auto">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="RSSI" Foreground="{DynamicResource OnSurfaceVariant}"
                                           FontSize="9" VerticalAlignment="Center" LetterSpacing="1" />
                                <ProgressBar Name="RssiBar" Grid.Row="0" Grid.Column="1" Minimum="0" Maximum="16"
                                             Value="0" Height="8" Foreground="{DynamicResource PrimaryAccent}" Background="{DynamicResource SurfaceContainerHigh}" />
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="TX" Foreground="{DynamicResource OnSurfaceVariant}"
                                           FontSize="9" VerticalAlignment="Center" Margin="0,6,0,0" LetterSpacing="1" />
                                <Border Name="TxIndicator" Grid.Row="1" Grid.Column="1" Height="8" Margin="0,6,0,0"
                                        Background="{DynamicResource SurfaceContainerHigh}" CornerRadius="2">
                                    <Border Name="TxIndicatorFill" Background="{DynamicResource SurfaceContainerHigh}" CornerRadius="2" HorizontalAlignment="Stretch" />
                                </Border>
                            </Grid>
                        </Border>

                        <!-- PTT button -->
                        <Border Name="MainPttButton" Height="60" CornerRadius="8"
                                Background="{DynamicResource PrimaryAccent}" Cursor="Hand" IsVisible="False"
                                PointerPressed="MainPttButton_PointerPressed"
                                PointerReleased="MainPttButton_PointerReleased">
                            <TextBlock Name="MainPttText" Text="PUSH TO TALK" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource OnPrimary}" HorizontalAlignment="Center"
                                       VerticalAlignment="Center" LetterSpacing="2" />
                        </Border>

                        <!-- WAV transmit buttons -->
                        <Grid Name="WavTransmitPanel" ColumnDefinitions="*,*" IsVisible="False">
                            <Button Name="MainSelectWavButton" Grid.Column="0" Content="Select WAV..."
                                    Click="MainSelectWav_Click" Padding="6,6" Margin="0,0,3,0"
                                    HorizontalAlignment="Stretch" FontSize="11" />
                            <Button Name="MainTransmitWavButton" Grid.Column="1" Content="Transmit File"
                                    Click="MainTransmitWav_Click" Padding="6,6" Margin="3,0,0,0"
                                    HorizontalAlignment="Stretch" FontSize="11" IsEnabled="False" />
                        </Grid>
                        <TextBlock Name="MainWavStatus" Text="" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10"
                                   HorizontalAlignment="Center" />

                        <!-- Status grid -->
                        <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,10">
                            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto,Auto">
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,3">
                                    <TextBlock Text="GPS" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Name="GpsText" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource OnSurface}" />
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,3">
                                    <TextBlock Text="SQUELCH" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Name="SquelchText" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource OnSurface}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,3">
                                    <TextBlock Text="SCAN" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Name="ScanText" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource OnSurface}" />
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,3">
                                    <TextBlock Text="POWER" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Name="PowerText" Text="--" FontSize="13" FontWeight="SemiBold" Foreground="{DynamicResource OnSurface}" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <!-- Channel list -->
                        <TextBlock Text="CHANNELS" FontSize="10" Foreground="{DynamicResource OnSurfaceVariant}"
                                   FontWeight="SemiBold" LetterSpacing="1.5" />
                        <ListBox Name="ChannelList" DoubleTapped="ChannelList_DoubleTapped"
                                 DragDrop.AllowDrop="True"
                                 Background="Transparent" Padding="0" BorderThickness="0">
                            <ListBox.ContextMenu>
                                <ContextMenu>
                                    <MenuItem Header="Set as VFO A" Click="ChannelSetVfoA_Click" />
                                    <MenuItem Header="Set as VFO B" Click="ChannelSetVfoB_Click" />
                                    <Separator />
                                    <MenuItem Header="Edit Channel..." Click="ChannelEdit_Click" />
                                    <Separator />
                                    <MenuItem Name="ChannelVfoAFreqModeItem" Header="VFO A Frequency Mode" Click="VfoAFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="ChannelVfoAFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Name="ChannelVfoBFreqModeItem" Header="VFO B Frequency Mode" Click="VfoBFreqMode_Click" IsVisible="False">
                                        <MenuItem.Icon>
                                            <CheckBox Name="ChannelVfoBFreqModeCheck" BorderThickness="0" IsHitTestVisible="False" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListBox.ContextMenu>
                            <ListBox.Styles>
                                <Style Selector="ListBoxItem">
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="MinHeight" Value="0" />
                                </Style>
                                <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#22FFFFFF" />
                                </Style>
                                <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                    <Setter Property="Background" Value="#11FFFFFF" />
                                </Style>
                            </ListBox.Styles>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,1" Padding="8,3" CornerRadius="4"
                                            Background="{Binding Background}">
                                        <Grid ColumnDefinitions="22,*,Auto">
                                            <TextBlock Grid.Column="0" Text="{Binding Id}" Foreground="{DynamicResource TertiaryText}" FontSize="10" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" Foreground="{Binding NameColor}"
                                                       FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <TextBlock Grid.Column="2" Text="{Binding Frequency}" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="10"
                                                       FontFamily="Consolas,Liberation Mono,monospace" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- Main tab control (tab strip hidden, controlled by sidebar) -->
            <TabControl Name="MainTabControl" Grid.Column="2" Margin="0"
                        Background="{DynamicResource SurfaceBase}">
                <TabControl.Styles>
                    <Style Selector="TabItem">
                        <Setter Property="MinHeight" Value="0" />
                        <Setter Property="Height" Value="0" />
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="Margin" Value="0" />
                        <Setter Property="IsHitTestVisible" Value="False" />
                    </Style>
                </TabControl.Styles>
                <TabItem Header="Communication">
                    <tabs:VoiceTabControl />
                </TabItem>
                <TabItem Header="Contacts">
                    <tabs:ContactsTabControl />
                </TabItem>
                <TabItem Header="Logbook">
                    <tabs:LogbookTabControl />
                </TabItem>
                <TabItem Header="Packets">
                    <tabs:PacketCaptureTabControl />
                </TabItem>
                <TabItem Header="Terminal">
                    <tabs:TerminalTabControl />
                </TabItem>
                <TabItem Header="BBS">
                    <tabs:BbsTabControl />
                </TabItem>
                <TabItem Header="Mail">
                    <tabs:MailTabControl />
                </TabItem>
                <TabItem Header="Torrent">
                    <tabs:TorrentTabControl />
                </TabItem>
                <TabItem Header="APRS">
                    <tabs:AprsTabControl />
                </TabItem>
                <TabItem Header="Map">
                    <tabs:MapTabControl />
                </TabItem>
                <TabItem Header="Debug">
                    <tabs:DebugTabControl />
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
