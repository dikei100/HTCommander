<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.BbsTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="BBS BOARD" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnSurface}" LetterSpacing="1" />
                    <TextBlock Name="BbsStatus" Text="Inactive"
                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <CheckBox Name="ViewTrafficCheck" Content="View Traffic"
                              IsChecked="True" Click="ViewTraffic_Click" />
                    <Button Name="ActivateButton" Content="Activate"
                            Click="ActivateButton_Click" Padding="12,4" IsEnabled="False"
                            Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}"
                            FontWeight="SemiBold" CornerRadius="4" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid RowDefinitions="*,14,Auto" Margin="14,14,14,0">
            <!-- DataGrid wrapped in Surface card -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="0" ClipToBounds="True">
                <DataGrid Name="BbsGrid" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserSortColumns="True"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Call Sign" Width="120" Binding="{Binding Callsign}" />
                        <DataGridTextColumn Header="Last Seen" Width="150" Binding="{Binding LastSeenStr}" />
                        <DataGridTextColumn Header="Packets In" Width="80" Binding="{Binding TotalPacketsIn}" />
                        <DataGridTextColumn Header="Packets Out" Width="80" Binding="{Binding TotalPacketsOut}" />
                        <DataGridTextColumn Header="Bytes In" Width="80" Binding="{Binding TotalBytesIn}" />
                        <DataGridTextColumn Header="Bytes Out" Width="80" Binding="{Binding TotalBytesOut}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Traffic log wrapped in SurfaceContainerLow card -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceContainerLow}" CornerRadius="8" Padding="14,12"
                    Height="150" Margin="0,0,0,14">
                <TextBox Name="TrafficLog" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="Consolas,Courier New,monospace" FontSize="11"
                         Background="Transparent" BorderThickness="0"
                         Foreground="{DynamicResource OnSurfaceVariant}" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
