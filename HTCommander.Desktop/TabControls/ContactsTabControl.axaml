<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.ContactsTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <TextBlock Text="STATION ROSTER" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnSurface}" LetterSpacing="1" />
                    <TextBlock Name="StationCount" Text="0 stations"
                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="6">
                    <Button Name="AddButton" Content="Add" Click="AddButton_Click" Padding="10,4" FontSize="11" />
                    <Button Name="EditButton" Content="Edit" Click="EditButton_Click"
                            Padding="10,4" IsEnabled="False" FontSize="11" />
                    <Button Name="RemoveButton" Content="Remove" Click="RemoveButton_Click"
                            Padding="10,4" IsEnabled="False" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid ColumnDefinitions="*,*" Margin="14,14,14,14">
            <!-- Left: Station list -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="0" Margin="0,0,7,0">
                <DataGrid Name="StationsGrid" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserReorderColumns="True"
                          CanUserSortColumns="True"
                          SelectionChanged="StationsGrid_SelectionChanged"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Callsign" Width="120" Binding="{Binding Callsign}" />
                        <DataGridTextColumn Header="Name" Width="150" Binding="{Binding Name}" />
                        <DataGridTextColumn Header="Type" Width="100" Binding="{Binding StationType}" />
                        <DataGridTextColumn Header="Description" Width="*" Binding="{Binding Description}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Right: Station detail card (placeholder) -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="16" Margin="7,0,0,0">
                <StackPanel Spacing="12" VerticalAlignment="Top">
                    <TextBlock Text="SELECT A STATION" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1.5"
                               HorizontalAlignment="Center" Margin="0,40,0,0" />
                    <TextBlock Text="Click a station in the roster to view details"
                               FontSize="12" Foreground="{DynamicResource Outline}"
                               HorizontalAlignment="Center" TextWrapping="Wrap" TextAlignment="Center" />
                </StackPanel>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
