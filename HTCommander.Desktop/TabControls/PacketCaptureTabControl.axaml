<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.PacketCaptureTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="AX.25 PACKET STREAM" FontSize="13" FontWeight="Bold"
                               Foreground="{DynamicResource OnSurface}" LetterSpacing="1" />
                    <TextBlock Name="PacketCount" Text="0 packets"
                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="6">
                    <CheckBox Name="ShowDecodeCheck" Content="Show Decode"
                              Click="ShowDecode_Click" FontSize="11" />
                    <Button Content="Clear" Click="ClearButton_Click" Padding="10,4" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Margin="14,14,14,14" RowDefinitions="*,14,Auto">
            <!-- Packet list -->
            <Border Grid.Row="0" Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="0">
                <DataGrid Name="PacketsGrid" AutoGenerateColumns="False"
                          IsReadOnly="True" CanUserSortColumns="True"
                          SelectionChanged="PacketsGrid_SelectionChanged"
                          Background="Transparent" BorderThickness="0">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Width="140" Binding="{Binding Time}" />
                        <DataGridTextColumn Header="Dir" Width="40" Binding="{Binding Direction}" />
                        <DataGridTextColumn Header="Channel" Width="100" Binding="{Binding Channel}" />
                        <DataGridTextColumn Header="Encoding" Width="80" Binding="{Binding Encoding}" />
                        <DataGridTextColumn Header="Data" Width="*" Binding="{Binding Data}" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>

            <!-- Decode panel -->
            <Border Grid.Row="2" Background="{DynamicResource SurfaceContainerLow}" CornerRadius="8"
                    Padding="12" MinHeight="140">
                <TextBox Name="DecodeText" IsReadOnly="True"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         FontFamily="Consolas,Liberation Mono,monospace" FontSize="11"
                         Background="Transparent" Foreground="{DynamicResource TextAreaForeground}"
                         BorderThickness="0" />
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
