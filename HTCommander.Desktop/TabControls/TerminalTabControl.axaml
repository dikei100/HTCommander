<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.TerminalTabControl">
    <DockPanel>
        <!-- Header -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="SYSTEM TERMINAL" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnSurface}" LetterSpacing="1" />
                    <TextBlock Name="ConnectionStatus" Text="Disconnected"
                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="6">
                    <ComboBox Name="StationCombo" Width="140" FontSize="11" />
                    <Button Name="ConnectButton" Content="Connect"
                            Click="ConnectButton_Click" Padding="10,4" IsEnabled="False" FontSize="11" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- Input area at bottom -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceContainerLow}" Padding="14,8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBox Name="InputBox" Grid.Column="0" Watermark="Enter command or packet data..."
                         KeyDown="InputBox_KeyDown" IsEnabled="False" FontFamily="Consolas,Liberation Mono,monospace" FontSize="12" />
                <Button Name="SendButton" Grid.Column="1" Content="TRANSMIT"
                        Click="SendButton_Click" Padding="16,6" Margin="8,0,0,0"
                        IsEnabled="False" FontWeight="Bold" FontSize="11"
                        Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}" CornerRadius="4" />
            </Grid>
        </Border>

        <!-- Terminal output -->
        <Border Margin="14" Background="{DynamicResource SurfaceContainerLow}" CornerRadius="8" Padding="2">
            <TextBox Name="TerminalOutput" IsReadOnly="True" AcceptsReturn="True"
                     TextWrapping="Wrap" FontFamily="Consolas,Liberation Mono,monospace"
                     FontSize="12" Background="Transparent" Foreground="{DynamicResource TextAreaForeground}"
                     BorderThickness="0" />
        </Border>
    </DockPanel>
</UserControl>
