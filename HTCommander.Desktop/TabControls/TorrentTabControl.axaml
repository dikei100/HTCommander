<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.TorrentTabControl">
    <DockPanel>
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="TORRENT FILES" FontSize="13" FontWeight="Bold" Foreground="{DynamicResource OnSurface}" LetterSpacing="1" />
                    <TextBlock Name="TorrentStatus" Text="Inactive"
                               VerticalAlignment="Center" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="4">
                    <Button Name="AddFileButton" Content="Add File"
                            Click="AddFileButton_Click" Padding="12,4" IsEnabled="False"
                            Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}"
                            FontWeight="SemiBold" CornerRadius="4" />
                    <Button Name="ActivateButton" Content="Activate"
                            Click="ActivateButton_Click" Padding="12,4" IsEnabled="False" CornerRadius="4" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Margin="14" ClipToBounds="True">
            <DataGrid Name="TorrentGrid" AutoGenerateColumns="False"
                      IsReadOnly="True" CanUserSortColumns="True"
                      Background="Transparent" BorderThickness="0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="File" Width="*" Binding="{Binding FileName}" />
                    <DataGridTextColumn Header="Source" Width="100" Binding="{Binding Source}" />
                    <DataGridTextColumn Header="Mode" Width="80" Binding="{Binding Mode}" />
                    <DataGridTextColumn Header="Size" Width="80" Binding="{Binding SizeStr}" />
                    <DataGridTextColumn Header="Progress" Width="100" Binding="{Binding Progress}" />
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </DockPanel>
</UserControl>
