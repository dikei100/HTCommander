<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="HTCommander.Desktop.TabControls.VoiceTabControl">
    <DockPanel>
        <!-- Header bar -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}" Height="46" Padding="14,0">
            <Grid>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="12">
                    <TextBlock Text="Communication" FontSize="14" FontWeight="SemiBold" Foreground="{DynamicResource OnSurface}" />
                    <TextBlock Name="VoiceStatus" Text="Idle" VerticalAlignment="Center"
                               Foreground="{DynamicResource OnSurfaceVariant}" FontSize="12" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                            VerticalAlignment="Center" Spacing="6">
                    <Button Name="SendSstvButton" Content="Send SSTV" Click="SendSstv_Click"
                            Padding="10,4" IsEnabled="False" FontSize="11" />
                    <ToggleButton Name="MuteButton" Content="Mute" Click="MuteButton_Click"
                                  Padding="10,4" FontSize="11" />
                    <ComboBox Name="ModeCombo" Width="100" SelectedIndex="0" FontSize="11">
                        <ComboBoxItem Content="Chat" />
                        <ComboBoxItem Content="Speak" />
                        <ComboBoxItem Content="Morse" />
                        <ComboBoxItem Content="DTMF" />
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Input area at bottom -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SurfaceContainerLow}" Padding="14,8">
            <Grid ColumnDefinitions="*,Auto,Auto">
                <TextBox Name="VoiceInput" Grid.Column="0" Watermark="Type message..."
                         KeyDown="VoiceInput_KeyDown" FontSize="12" />
                <Button Name="TransmitButton" Grid.Column="1" Content="Transmit"
                        Click="TransmitButton_Click" Padding="16,6" Margin="8,0,0,0" IsEnabled="False"
                        Background="{DynamicResource PrimaryAccent}" Foreground="{DynamicResource OnPrimary}"
                        FontWeight="SemiBold" FontSize="12" CornerRadius="4" />
                <Button Name="RecordButton" Grid.Column="2" Content="Record"
                        Click="RecordButton_Click" Padding="10,6" Margin="4,0,0,0" FontSize="12" />
            </Grid>
        </Border>

        <!-- Main content: two columns -->
        <Grid ColumnDefinitions="*,*" Margin="0">

            <!-- Left column: SSTV / Local Packet Node area -->
            <Border Grid.Column="0" Background="{DynamicResource SurfaceBase}" Margin="14,14,7,14">
                <DockPanel>
                    <!-- SSTV decode panel -->
                    <Border Name="SstvDecodePanel" DockPanel.Dock="Top" Background="{DynamicResource SurfaceContainer}"
                            CornerRadius="8" Padding="14,12" IsVisible="False" Margin="0,0,0,12">
                        <StackPanel Spacing="6">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="SSTV DECODING" FontWeight="SemiBold" FontSize="10"
                                           Foreground="{DynamicResource PrimaryAccent}" LetterSpacing="1.5" />
                                <TextBlock Name="SstvModeText" Text="" Foreground="{DynamicResource OnSurfaceVariant}" FontSize="11" />
                            </StackPanel>
                            <ProgressBar Name="SstvProgressBar" Minimum="0" Maximum="100" Value="0" Height="6"
                                         Foreground="{DynamicResource PrimaryAccent}" />
                            <Border Background="{DynamicResource SurfaceContainerLow}" Height="200" CornerRadius="6">
                                <Image Name="SstvPreviewImage" Stretch="Uniform" />
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- Local Packet Node placeholder -->
                    <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                        <StackPanel Spacing="8">
                            <TextBlock Text="LOCAL PACKET NODE" FontSize="10" FontWeight="SemiBold"
                                       Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1.5" />
                            <Border Background="{DynamicResource SurfaceContainerLow}" CornerRadius="6"
                                    Height="200" Padding="16">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="6">
                                    <TextBlock Text="SSTV / DATA LINK" FontSize="12"
                                               Foreground="{DynamicResource OnSurfaceVariant}"
                                               HorizontalAlignment="Center" FontWeight="SemiBold" />
                                    <TextBlock Text="Waiting for incoming data..."
                                               FontSize="11" Foreground="{DynamicResource Outline}"
                                               HorizontalAlignment="Center" />
                                </StackPanel>
                            </Border>
                            <Grid ColumnDefinitions="*,*" Margin="0,4,0,0">
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="STATUS" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Text="Standby" FontSize="12" Foreground="{DynamicResource TertiaryAccent}" FontWeight="SemiBold" />
                                </StackPanel>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="PROTOCOL" FontSize="9" Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1" />
                                    <TextBlock Text="AX.25" FontSize="12" Foreground="{DynamicResource OnSurface}" FontWeight="SemiBold" />
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>
                </DockPanel>
            </Border>

            <!-- Right column: Operation log / chat messages -->
            <Border Grid.Column="1" Background="{DynamicResource SurfaceBase}" Margin="7,14,14,14">
                <Border Background="{DynamicResource SurfaceContainer}" CornerRadius="8" Padding="14,12">
                    <DockPanel>
                        <TextBlock DockPanel.Dock="Top" Text="OPERATION" FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource OnSurfaceVariant}" LetterSpacing="1.5" Margin="0,0,0,10" />
                        <ScrollViewer Name="MessagesScroller">
                            <StackPanel Name="VoiceMessages" Spacing="6" />
                        </ScrollViewer>
                    </DockPanel>
                </Border>
            </Border>
        </Grid>
    </DockPanel>
</UserControl>
